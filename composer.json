{
    "name": "ryangjchandler/downmark",
    "description": "A speedy Markdown parser for PHP applications.",
    "keywords": [
        "ryangjchandler",
        "downmark"
    ],
    "homepage": "https://github.com/ryangjchandler/downmark",
    "license": "MIT",
    "authors": [
        {
            "name": "Ryan Chandler",
            "email": "support@ryangjchandler.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/macroable": "^9.5"
    },
    "require-dev": {
        "erusev/parsedown": "^1.7",
        "friendsofphp/php-cs-fixer": "^3.0",
        "league/commonmark": "^2.2",
        "michelf/php-markdown": "^1.9",
        "pestphp/pest": "^1.20",
        "phpbench/phpbench": "^1.2",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "Downmark\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Downmark\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
